{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ProgramViz: 配置 Debug",
      "type": "process",
      "command": "/usr/local/bin/cmake",
      "args": ["--preset", "debug"],
      "problemMatcher": []
    },
    {
      "label": "ProgramViz: 编译 Debug",
      "type": "process",
      "command": "/usr/local/bin/cmake",
      "args": ["--build", "--preset", "debug", "--parallel"],
      "dependsOn": "ProgramViz: 配置 Debug",
      "dependsOrder": "sequence",
      "problemMatcher": "$gcc",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "ProgramViz: 配置 Release",
      "type": "process",
      "command": "/usr/local/bin/cmake",
      "args": ["--preset", "release"],
      "problemMatcher": []
    },
    {
      "label": "ProgramViz: 构建 Release",
      "type": "process",
      "command": "/usr/local/bin/cmake",
      "args": ["--build", "--preset", "release", "--parallel"],
      "dependsOn": "ProgramViz: 配置 Release",
      "dependsOrder": "sequence",
      "problemMatcher": "$gcc",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "ProgramViz: 运行 Debug",
      "type": "process",
      "command": "/usr/bin/open",
      "args": ["${workspaceFolder}/build/debug/ProgramViz.app"],
      "dependsOn": "ProgramViz: 编译 Debug",
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "ProgramViz: 清理构建产物",
      "type": "process",
      "command": "/usr/local/bin/cmake",
      "args": ["--build", "--preset", "debug", "--target", "clean"],
      "problemMatcher": []
    }
  ]
}
